{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "data",
    "source": "\u001b[34m                 @@@@@@@@@                 \n             @@  -   =   .* @@             \n           @ =.+*+=*@  @  ::.: @@          \n         @ #-=:-:=%     @@  ::.  @         \n        @ ==:=+#*@      @@@     : @        \n       @ :--+#           @ @@@@  . @       \n       @ ==*            @  @==%@    @      \n      @ -*             @@@@@*+=%@@  @      \n      @              @@%==+=-#===#@ @      \n      @@           @@@@@@@@@@@@@@@@ @      \n       @@@@@@@@@@@                  @      \n       @@@*==+-==%@@@@@            @       \n         @%+===+++=#@@            @        \n          @@@*++=%@@            @@         \n            @@=@=%            @@           \n               @@@@      @@@@              \u001b[0m",
    "padding": {
      "right": 3
    }
  },
  "display": {
    "separator": "  ",
    "color": {
      "keys": "blue",
      "title": "cyan"
    }
  },
  "modules": [
    "title",
    "separator",
    { "type": "os",       "key": "OS" },
    { "type": "host",     "key": "Host" },
    { "type": "kernel",   "key": "Kernel" },
    { "type": "uptime",   "key": "Uptime" },
    { "type": "packages", "key": "Packages" },
    { "type": "shell",    "key": "Shell" },
    "separator",
    { "type": "de",       "key": "DE" },
    { "type": "wm",       "key": "WM" },
    { "type": "terminal", "key": "Terminal" },
    { "type": "display",  "key": "Display" },
    "separator",
    { "type": "cpu",      "key": "CPU" },
    { "type": "gpu",      "key": "GPU" },
    { "type": "memory",   "key": "Memory" },
    {
      "type": "disk",
      "key": "Disk",
      "folders": "/"
    },
    "separator",
    {
      "type": "colors",
      "paddingLeft": 1,
      "symbol": "circle"
    }
  ]
}
