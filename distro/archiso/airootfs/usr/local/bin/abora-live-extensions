#!/usr/bin/env bash
set -euo pipefail

state_file="/tmp/abora-live-extensions.prompted"

if [[ ! -d /run/archiso ]]; then
    exit 0
fi

if [[ ! -t 0 ]] || [[ ! -t 1 ]]; then
    exit 0
fi

if [[ -f "$state_file" ]]; then
    exit 0
fi
touch "$state_file"

clear
printf '============================================\n'
printf '         Abora Live Extension Setup         \n'
printf '============================================\n\n'
printf 'Install optional extensions before KDE starts.\n\n'
printf '1) Install TinyPM extension (if available)\n'
printf '2) Skip and start KDE\n\n'

choice="2"
read -r -t 20 -p "Choose [1-2] (auto-skip in 20s): " choice || true

install_tinypm() {
    local pkg=""
    for candidate in tinypm-abora tinypm; do
        if pacman -Si "$candidate" >/dev/null 2>&1; then
            pkg="$candidate"
            break
        fi
    done

    if [[ -z "$pkg" ]]; then
        printf '\nTinyPM package was not found in configured repositories.\n'
        return 0
    fi

    printf '\nInstalling %s ...\n' "$pkg"
    if sudo pacman -S --needed --noconfirm "$pkg"; then
        printf 'TinyPM installation complete.\n'
    else
        printf 'TinyPM install failed. KDE will still start.\n'
    fi
}

case "$choice" in
    1)
        install_tinypm
        ;;
    *)
        printf '\nSkipping extension install.\n'
        ;;
esac

printf '\nStarting KDE Plasma...\n'
sleep 1
