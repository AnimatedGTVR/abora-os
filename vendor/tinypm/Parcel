#!/usr/bin/env bash
set -euo pipefail

script_path="${BASH_SOURCE[0]}"
while [[ -L "$script_path" ]]; do
    script_parent="$(cd -P "$(dirname "$script_path")" && pwd)"
    script_target="$(readlink "$script_path")"
    if [[ "$script_target" == /* ]]; then
        script_path="$script_target"
    else
        script_path="$script_parent/$script_target"
    fi
done

script_dir="$(cd -P "$(dirname "$script_path")" && pwd)"

case "${1:---version}" in
    ""|version|-v|--version)
        shift || true
        exec "$script_dir/version" "$@"
        ;;
    help|-h|--help)
        . "$script_dir/lib/core/config.sh"
        . "$script_dir/lib/core/common.sh"
        printf '%s is the %s core engine.\n' "$tinypm_engine_name" "$tinypm_system_name"
        [[ -n "$tinypm_tagline" ]] && printf '%s\n' "$tinypm_tagline"
        cat <<EOF2

Usage:
  $tinypm_engine_name --version
  grab <package>
  tinypm help
EOF2
        ;;
    *)
        exec "$script_dir/tinypm" "$@"
        ;;
esac
