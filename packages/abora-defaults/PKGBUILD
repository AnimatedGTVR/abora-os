pkgname=abora-defaults
pkgver=0.1.0
pkgrel=6
pkgdesc="Default configuration and first-boot experience for Abora OS"
arch=('any')
url="https://github.com/AnimatedGTVR/abora-os"
license=('MIT')
depends=('bash' 'kdialog' 'networkmanager' 'plasma-meta' 'polkit-kde-agent' 'sddm')
source=(
  'abora-installer-launcher'
  'abora-initial-setup'
  'optional-software-install'
  'abora-initial-setup.desktop'
  'abora-doctor'
  'fastfetch-config.jsonc'
  'sddm-autologin.conf'
  'kdeglobals'
  'kwinrc'
  'plasma-org.kde.plasma.desktop-appletsrc'
  '90-abora.preset'
)
sha256sums=(
  '9d1ae97ce074c43050f8226a7961889f4bf2b5ee23c0b404ef7b34bffa9882df'
  'dd4c2eab569c9a2f057308f32ee3c5b385d943d5e8cc9b7b432f37c01ee41e26'
  'f27192c4cdbb22bc4ab2c9033f656055dd0394f74a99dc231a3fa3bb796a1924'
  'f741395d7744c50f1f1261b4f80d699ed89ca77cb200edcb3c891f241c68ad0a'
  '318a263a38888e9695c8ce6abd0e2fb107d855af23b68c12f52421636c0e9cd9'
  'bf5313012796f991b2dcbf0340468d63acbe3caeab4f11b2ea15aa272880c14c'
  'bd0d4c70c990cd915c6b55f1d5e0163285354285803a4330b7ac2470a56479a3'
  '257891cb24c33e949ca6dd3db98da51ca677511b0a934a6c5774172ad8b3fff6'
  '2455eea8a123282b56d05568661568f478ac1e8fa71d5ea39a902789511f984f'
  '03d05ffb542e10f0908e73312fdda47d28d23173e4f22a3a869c8d8063809cd6'
  '0201cbe2635d123e4b876b04d3586d628bd432320b4efddc5da7af409263eb89'
)

package() {
  install -Dm755 "$srcdir/abora-installer-launcher" "$pkgdir/usr/bin/abora-installer-launcher"
  install -Dm755 "$srcdir/abora-initial-setup" "$pkgdir/usr/bin/abora-initial-setup"
  install -Dm755 "$srcdir/optional-software-install" "$pkgdir/usr/lib/abora/optional-software-install"
  install -Dm644 "$srcdir/abora-initial-setup.desktop" "$pkgdir/etc/skel/.config/autostart/abora-initial-setup.desktop"
  install -Dm755 "$srcdir/abora-doctor" "$pkgdir/usr/bin/abora-doctor"
  install -Dm644 "$srcdir/fastfetch-config.jsonc" "$pkgdir/etc/xdg/fastfetch/config.jsonc"
  install -Dm644 "$srcdir/fastfetch-config.jsonc" "$pkgdir/etc/skel/.config/fastfetch/config.jsonc"
  install -Dm644 "$srcdir/sddm-autologin.conf" "$pkgdir/etc/sddm.conf.d/autologin.conf"
  install -Dm644 "$srcdir/kdeglobals" "$pkgdir/etc/skel/.config/kdeglobals"
  install -Dm644 "$srcdir/kwinrc" "$pkgdir/etc/skel/.config/kwinrc"
  install -Dm644 "$srcdir/plasma-org.kde.plasma.desktop-appletsrc" "$pkgdir/etc/skel/.config/plasma-org.kde.plasma.desktop-appletsrc"
  install -Dm644 "$srcdir/90-abora.preset" "$pkgdir/usr/lib/systemd/system-preset/90-abora.preset"
  install -d "$pkgdir/etc/systemd/system"
  ln -sf /dev/null "$pkgdir/etc/systemd/system/systemd-firstboot.service"
}
