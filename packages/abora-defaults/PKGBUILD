pkgname=abora-defaults
pkgver=0.1.0
pkgrel=1
pkgdesc="Default configuration and first-boot experience for Abora OS"
arch=('any')
url="https://github.com/AnimatedGTVR/abora-os"
license=('MIT')
depends=('bash' 'kdialog' 'sddm' 'networkmanager' 'plasma-meta')
source=(
  'abora-welcome'
  'abora-doctor'
  'abora-firstboot.desktop'
  'sddm-autologin.conf'
  'kdeglobals'
  'kwinrc'
  'plasma-org.kde.plasma.desktop-appletsrc'
  '90-abora.preset'
)
sha256sums=(
  '230ca1423effad00e662e912885db4b20655bb52ae4e0b5a946ecb3be163cb70'
  '681f716285f409053b1f8581425054665d6479a82c9f769fb99b1b29bfb8b8d6'
  '5d4f104d8870dd2315076f78d14d257c025046cef30bef32926b170176003e42'
  'bd0d4c70c990cd915c6b55f1d5e0163285354285803a4330b7ac2470a56479a3'
  '257891cb24c33e949ca6dd3db98da51ca677511b0a934a6c5774172ad8b3fff6'
  '2455eea8a123282b56d05568661568f478ac1e8fa71d5ea39a902789511f984f'
  '03d05ffb542e10f0908e73312fdda47d28d23173e4f22a3a869c8d8063809cd6'
  '844f729a940b6b6f0e8a748fba80d8ce1c0d266d35c84873b85bbd84e4dc511e'
)

package() {
  install -Dm755 "$srcdir/abora-welcome" "$pkgdir/usr/bin/abora-welcome"
  install -Dm755 "$srcdir/abora-doctor" "$pkgdir/usr/bin/abora-doctor"
  install -Dm644 "$srcdir/abora-firstboot.desktop" "$pkgdir/etc/skel/Desktop/Welcome to Abora.desktop"
  install -Dm644 "$srcdir/abora-firstboot.desktop" "$pkgdir/etc/skel/.config/autostart/Welcome to Abora.desktop"
  install -Dm644 "$srcdir/sddm-autologin.conf" "$pkgdir/etc/sddm.conf.d/autologin.conf"
  install -Dm644 "$srcdir/kdeglobals" "$pkgdir/etc/skel/.config/kdeglobals"
  install -Dm644 "$srcdir/kwinrc" "$pkgdir/etc/skel/.config/kwinrc"
  install -Dm644 "$srcdir/plasma-org.kde.plasma.desktop-appletsrc" "$pkgdir/etc/skel/.config/plasma-org.kde.plasma.desktop-appletsrc"
  install -Dm644 "$srcdir/90-abora.preset" "$pkgdir/usr/lib/systemd/system-preset/90-abora.preset"
}
