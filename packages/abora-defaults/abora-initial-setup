#!/usr/bin/env bash
set -euo pipefail

kdialog_bin="/usr/bin/kdialog"
installer_helper="/usr/lib/abora/optional-software-install"
state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/abora"
state_file="$state_dir/optional-setup.done"

if [[ "${USER:-}" == "liveuser" ]] || [[ -d /run/archiso ]]; then
    exit 0
fi

if [[ ! -x "$kdialog_bin" ]] || [[ ! -x "$installer_helper" ]]; then
    exit 0
fi

if [[ -f "$state_file" ]]; then
    exit 0
fi

mkdir -p "$state_dir"

if ! "$kdialog_bin" \
    --title "Abora Initial Setup" \
    --yesno "Would you like to install optional software now?\n\nYou can pick TinyPM, GNOME, Hyprland, or keep KDE only."; then
    touch "$state_file"
    exit 0
fi

choices="$("$kdialog_bin" \
    --title "Abora Optional Software" \
    --separate-output \
    --checklist "Select optional components to install:" \
    "tinypm" "Install TinyPM package manager (if available)." off \
    "gnome" "Install GNOME desktop environment packages." off \
    "hyprland" "Install Hyprland compositor packages." off \
    "kde" "Ensure KDE Plasma packages are installed." on)" || exit 0

if [[ -z "$choices" ]]; then
    touch "$state_file"
    "$kdialog_bin" --title "Abora Initial Setup" --msgbox "No optional components selected."
    exit 0
fi

mapfile -t options <<<"$choices"

if pkexec "$installer_helper" "${options[@]}"; then
    touch "$state_file"
    "$kdialog_bin" --title "Abora Initial Setup" --msgbox "Optional software setup completed."
else
    "$kdialog_bin" --title "Abora Initial Setup" --error "Optional software install failed. Check /var/log/abora-optional-setup.log."
fi
