[Desktop Entry]
Type=Application
Version=1.0
Name=Welcome to Abora
GenericName=First Boot Guide
Comment=Open the Abora welcome and health-check screen
Exec=abora-welcome
Icon=preferences-desktop
Terminal=false
Categories=System;Settings;
StartupNotify=true
X-GNOME-Autostart-enabled=true
X-KDE-autostart-after=panel
