#!/usr/bin/env bash
set -euo pipefail

calamares_cmd="/usr/bin/calamares"
log_file="/tmp/abora-calamares-launcher.log"
xauth="${XAUTHORITY:-$HOME/.Xauthority}"

printf 'launcher start %s user=%s uid=%s\n' \
    "$(date -Is)" \
    "${USER:-unknown}" \
    "$(id -u)" >>"$log_file"
exec >>"$log_file" 2>&1

detect_airootfs_source() {
    local link_path="/tmp/abora-airootfs.sfs"
    local candidate

    rm -f "$link_path"

    for candidate in \
        /run/archiso/bootmnt/abora/x86_64/airootfs.sfs \
        /run/archiso/bootmnt/arch/x86_64/airootfs.sfs \
        /run/archiso/copytoram/airootfs.sfs
    do
        if [[ -f "$candidate" ]]; then
            ln -sfn "$candidate" "$link_path"
            printf 'using airootfs source %s via %s\n' "$candidate" "$link_path"
            return 0
        fi
    done

    printf 'could not find airootfs.sfs in known locations\n'
    return 1
}

if [[ ! -x "$calamares_cmd" ]]; then
    printf 'Calamares is missing from this image.\n' >&2
    printf 'calamares binary missing at %s\n' "$calamares_cmd"
    exit 1
fi

if ! detect_airootfs_source; then
    printf 'Failed to locate live filesystem image required by installer.\n' >&2
    if command -v kdialog >/dev/null 2>&1; then
        kdialog --error "Installer could not find airootfs.sfs. Check /tmp/abora-calamares-launcher.log for details."
    fi
    exit 1
fi

printf 'display vars DISPLAY=%s XAUTHORITY=%s XDG_RUNTIME_DIR=%s WAYLAND_DISPLAY=%s\n' \
    "${DISPLAY:-}" \
    "$xauth" \
    "${XDG_RUNTIME_DIR:-}" \
    "${WAYLAND_DISPLAY:-}"

if [[ "$(id -u)" -eq 0 ]]; then
    exec env QT_QPA_PLATFORM=xcb "$calamares_cmd" -d
fi

if [[ "${USER:-}" = "liveuser" ]]; then
    exec sudo env \
        DISPLAY="${DISPLAY:-}" \
        XAUTHORITY="$xauth" \
        DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-}" \
        XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-}" \
        WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-}" \
        QT_QPA_PLATFORM=xcb \
        "$calamares_cmd" -d
fi

exec pkexec env \
    DISPLAY="${DISPLAY:-}" \
    XAUTHORITY="$xauth" \
    DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-}" \
    XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-}" \
    WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-}" \
    QT_QPA_PLATFORM=xcb \
    "$calamares_cmd" -d
