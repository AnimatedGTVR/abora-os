#!/usr/bin/env bash
set -euo pipefail

calamares_cmd="/usr/bin/calamares"
xauth="${XAUTHORITY:-$HOME/.Xauthority}"

if [[ ! -x "$calamares_cmd" ]]; then
    printf 'Calamares is missing from this image.\n' >&2
    exit 1
fi

if [[ "$(id -u)" -eq 0 ]]; then
    exec "$calamares_cmd"
fi

if [[ "${USER:-}" = "liveuser" ]]; then
    exec sudo --preserve-env=DISPLAY,XAUTHORITY,DBUS_SESSION_BUS_ADDRESS,XDG_RUNTIME_DIR,WAYLAND_DISPLAY \
        env \
        DISPLAY="${DISPLAY:-}" \
        XAUTHORITY="$xauth" \
        DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-}" \
        XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-}" \
        WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-}" \
        "$calamares_cmd"
fi

exec pkexec env \
    DISPLAY="${DISPLAY:-}" \
    XAUTHORITY="$xauth" \
    DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-}" \
    XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-}" \
    WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-}" \
    "$calamares_cmd"
