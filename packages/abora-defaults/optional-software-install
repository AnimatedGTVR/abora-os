#!/usr/bin/env bash
set -euo pipefail

log_file="/var/log/abora-optional-setup.log"
mkdir -p "$(dirname "$log_file")"
touch "$log_file"
chmod 0644 "$log_file"
exec >>"$log_file" 2>&1

printf '\n[%s] optional software install start\n' "$(date -Is)"

if [[ "${EUID}" -ne 0 ]]; then
    echo "This helper must run as root."
    exit 1
fi

if [[ "$#" -eq 0 ]]; then
    echo "No optional components were requested."
    exit 0
fi

has_pkg() {
    pacman -Si "$1" >/dev/null 2>&1
}

declare -A requested_pkg_map=()
missing_entries=()

add_pkg_if_available() {
    local pkg="$1"
    if has_pkg "$pkg"; then
        requested_pkg_map["$pkg"]=1
    else
        missing_entries+=("$pkg")
    fi
}

for raw_opt in "$@"; do
    opt="${raw_opt//\"/}"
    case "$opt" in
        tinypm)
            if has_pkg tinypm-abora; then
                requested_pkg_map["tinypm-abora"]=1
            elif has_pkg tinypm; then
                requested_pkg_map["tinypm"]=1
            else
                missing_entries+=("tinypm-abora/tinypm")
            fi
            ;;
        gnome)
            add_pkg_if_available gnome
            add_pkg_if_available gnome-tweaks
            add_pkg_if_available gdm
            ;;
        hyprland)
            add_pkg_if_available hyprland
            add_pkg_if_available xdg-desktop-portal-hyprland
            add_pkg_if_available waybar
            add_pkg_if_available kitty
            ;;
        kde)
            add_pkg_if_available plasma-meta
            add_pkg_if_available sddm
            ;;
        *)
            echo "Ignoring unknown option: $opt"
            ;;
    esac
done

packages=()
for pkg in "${!requested_pkg_map[@]}"; do
    packages+=("$pkg")
done

if [[ "${#packages[@]}" -eq 0 ]]; then
    echo "No installable packages were selected."
    if [[ "${#missing_entries[@]}" -gt 0 ]]; then
        printf 'Missing packages: %s\n' "${missing_entries[*]}"
    fi
    exit 1
fi

echo "Installing packages: ${packages[*]}"
pacman -S --needed --noconfirm "${packages[@]}"

if [[ "${#missing_entries[@]}" -gt 0 ]]; then
    printf 'Some package entries were not found: %s\n' "${missing_entries[*]}"
fi

echo "Optional software install finished successfully."
