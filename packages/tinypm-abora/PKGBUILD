pkgname=tinypm-abora
pkgver=1.0.1.r12.gbec274c
pkgrel=1
pkgdesc="Abora-packaged TinyPM wrapper and runtime"
arch=('any')
url="https://github.com/AnimatedGTVR/TinyPM"
license=('GPL-3.0-or-later')
depends=('bash' 'pacman')
makedepends=('git')
optdepends=(
  'flatpak: Flatpak backend support'
  'snapd: Snap backend support'
  'polkit: graphical privilege escalation'
)
source=(
  "git+$url.git"
  "tinypm-launcher"
)
sha256sums=(
  'SKIP'
  '9f812cc34bdd4388a4ebf55c630c2ed7890f562204e9d1eaf1270d792f1e6d3e'
)

pkgver() {
  cd TinyPM
  git describe --tags --long --abbrev=7 | sed 's/^v//; s/-/.r/; s/-/./'
}

package() {
  cd TinyPM

  install -d "$pkgdir/usr/lib/tinypm"
  cp -a . "$pkgdir/usr/lib/tinypm/"

  rm -rf \
    "$pkgdir/usr/lib/tinypm/.git" \
    "$pkgdir/usr/lib/tinypm/.github"

  install -Dm755 "$srcdir/tinypm-launcher" "$pkgdir/usr/lib/tinypm/tinypm-launcher"

  install -d "$pkgdir/usr/bin"
  for cmd in tinypm tiny ainstall search term start supdate seed seedstore syspm tinypm-app version; do
    ln -s "/usr/lib/tinypm/tinypm-launcher" "$pkgdir/usr/bin/$cmd"
  done

  install -Dm644 "$srcdir/TinyPM/flavors/abora/tinypm.desktop" \
    "$pkgdir/usr/share/applications/tinypm.desktop"
}
