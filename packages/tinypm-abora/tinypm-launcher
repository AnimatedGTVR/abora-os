#!/usr/bin/env bash
set -euo pipefail

runtime_root="/usr/lib/tinypm"
cmd_name="$(basename "$0")"

export TINYPM_FLAVOR=abora

case "$cmd_name" in
  tinypm|tiny)
    exec "$runtime_root/tinypm" "$@"
    ;;
  ainstall)
    exec "$runtime_root/tinypm" install "$@"
    ;;
  search)
    exec "$runtime_root/tinypm" search "$@"
    ;;
  term)
    exec "$runtime_root/tinypm" remove "$@"
    ;;
  start)
    exec "$runtime_root/tinypm" run "$@"
    ;;
  supdate)
    exec "$runtime_root/tinypm" update "$@"
    ;;
  seed|seedstore)
    exec "$runtime_root/seed" "$@"
    ;;
  syspm)
    exec "$runtime_root/syspm.sh" "$@"
    ;;
  tinypm-app)
    exec "$runtime_root/tinypm-app" "$@"
    ;;
  version)
    exec "$runtime_root/version" "$@"
    ;;
  *)
    printf 'tinypm-launcher: unsupported command: %s\n' "$cmd_name" >&2
    exit 1
    ;;
esac
