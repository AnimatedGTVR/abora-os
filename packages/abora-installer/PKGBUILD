pkgname=abora-installer
pkgver=0.1.0
pkgrel=1
pkgdesc="Abora OS Calamares launcher"
arch=('any')
url="https://github.com/AnimatedGTVR/abora-os"
license=('MIT')
depends=('bash' 'calamares' 'polkit')
source=(
  'abora-installer-launcher'
  'abora-installer.desktop'
)
sha256sums=(
  'd49241551a4b658f5ac47d33a9c30139e9ee3807c9dba7ce80097b11731f95d5'
  'ff7469b98f5168aa9c693190b5dcdef2e6d0866168797cb1505b7d8ac485231b'
)

package() {
  install -Dm755 "$srcdir/abora-installer-launcher" "$pkgdir/usr/bin/abora-installer-launcher"
  install -Dm644 "$srcdir/abora-installer.desktop" "$pkgdir/usr/share/applications/abora-installer.desktop"
}
