#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "--print-guide" ]]; then
    cat /usr/share/abora-installer/installer-guide.txt
    exit 0
fi

if [[ "$(id -u)" -ne 0 ]]; then
    echo "Abora Installer must run as root." >&2
    echo "Use the desktop launcher or run: pkexec /usr/bin/abora-installer-launcher" >&2
    exit 1
fi

clear
cat <<'EOF'
Abora Installer
===============

This starts the guided Arch installer used by Abora.

Recommended choices inside archinstall:
  - Profile: Desktop -> KDE Plasma
  - Network: NetworkManager
  - Audio: PipeWire
  - Bootloader: systemd-boot on UEFI, GRUB on BIOS

Press Enter to continue into archinstall.
EOF
read -r

exec archinstall --advanced
